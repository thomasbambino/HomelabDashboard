# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@db:5432/gamelab

# Plex Integration
PLEX_TOKEN=your_plex_token_here
PLEX_URL=http://your-plex-server:32400  # Use your local Plex server URL here

# Email Service Configuration (Mailgun)
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=your_mailgun_domain_here
MAILGUN_FROM_EMAIL=noreply@yourdomain.com

# Game Server Management (AMP)
AMP_API_URL=your_amp_api_url_here
AMP_API_USERNAME=your_amp_username_here
AMP_API_PASSWORD=your_amp_password_here

# Chat Integration (Stream)
STREAM_API_KEY=your_stream_api_key_here
STREAM_API_SECRET=your_stream_api_secret_here

# Security Configuration
SESSION_SECRET=your_session_secret_here  # Generate a strong random string for production

# Local Deployment Settings
NODE_ENV=production
PORT=5000

# Note: Copy this file to .env and replace the placeholder values with your actual credentials
# Never commit the actual .env file to version control